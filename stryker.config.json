{
  "$schema": "https://schema.stryker-mutator.io/stryker-config.json",
  "mutate": [
    "src/Domain/**/*.ts",
    "src/EntryPoints/**/*.ts",
    "!src/Domain/**/Entity/*.ts",
    "!src/Domain/**/*.{test,spec}.ts",
    "!src/EntryPoints/**/*.{test,spec}.ts"
  ],
  "testRunner": "jest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.ts",
    "config": {
      "testMatch": ["**/src/**/*.spec.ts", "**/src/**/*.test.ts"]
    }
  },
  "reporters": ["progress", "clear-text", "html"],
  "concurrency": 2,
  "incremental": true,
  "ignoreStatic": true,
  "coverageAnalysis": "perTest",
  "thresholds": {
    "break": 60
  }
}
