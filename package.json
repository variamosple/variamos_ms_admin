{
  "name": "variamos-ms-admin",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "npx ts-node build.ts",
    "lint": "eslint src/",
    "lint:diff": "git diff HEAD --name-only | grep -E '\\.(ts|js)$' | xargs -r npx eslint",
    "lint:diff:fix": "git diff HEAD --name-only | grep -E '\\.(ts|js)$' | xargs -r npx eslint --fix",
    "prettier:diff": "git diff HEAD --name-only | grep -E '\\.(ts|js|json|css|md)$' | xargs -r npx prettier --write",
    "fix:all": "npm run prettier:diff && npm run lint:diff:fix",
    "start": "node -r module-alias/register ./dist --env=production",
    "dev": "nodemon",
    "test": "jest",
    "test:unit": "jest src/Domain",
    "test:integration": "jest src/EntryPoints",
    "test:coverage": "jest --coverage",
    "prepare": "husky",
    "check-arch": "dependency-cruiser --config .dependency-cruiser.js src/",
    "typecheck": "tsc --noEmit",
    "find-deadcode": "knip"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts, html",
    "ignore": [
      "src/public"
    ],
    "exec": "./node_modules/.bin/ts-node --files -r tsconfig-paths/register ./src"
  },
  "_moduleAliases": {
    "@src": "dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@variamosple/variamos-security": "^0.0.15",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "cookie": "^1.0.2",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "google-auth-library": "^9.14.1",
    "helmet": "^7.1.0",
    "jet-logger": "^1.3.1",
    "module-alias": "^2.2.3",
    "morgan": "~1.9.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.12.0",
    "sequelize": "^6.37.3",
    "ts-command-line-args": "^2.5.1",
    "uuid": "^11.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.31",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "cspell": "^9.8.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "knip": "^6.24.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
